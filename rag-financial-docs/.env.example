# =============================================================================
# RAG Financial Docs — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# OpenAI
OPENAI_API_KEY=sk-...

# LangSmith (optional but recommended for observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=rag-financial-docs

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                     # Leave empty for local Docker instance

# Collection names
QDRANT_COLLECTION=financial_docs

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=100

# LLM settings
LLM_MODEL=gpt-4o-mini               # or gpt-4o for higher quality
LLM_TEMPERATURE=0.0                 # 0 = deterministic, good for factual Q&A
LLM_MAX_TOKENS=1024

# Retrieval settings
RETRIEVAL_TOP_K=10                  # How many chunks to retrieve initially
RERANKER_TOP_N=3                    # How many chunks to keep after reranking

# Chunking defaults
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Paths
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_EVAL_DIR=data/eval
